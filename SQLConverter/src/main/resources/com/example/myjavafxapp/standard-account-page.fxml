<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.text.*?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="standardAccountPage" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.myjavafxapp.AccountController">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>

    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
        <Label layoutX="237.0" layoutY="222.0" prefHeight="38.0" prefWidth="80.0" text="Email">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <TextField fx:id="standardEmailInputField" layoutX="236.0" layoutY="258.0" prefHeight="45.0" prefWidth="251.0" promptText="Email">
            <font>
                <Font size="18.0" />
            </font>
        </TextField>
        <Label fx:id="emailExistsError" layoutX="105.0" layoutY="190.0" text="Email already registered, please log in" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextField fx:id="standardPasswordInputField" layoutX="598.0" layoutY="255.0" prefHeight="45.0" prefWidth="251.0" promptText="Password">
            <font>
                <Font size="18.0" />
            </font>
        </TextField>
        <Label fx:id="passwordError" layoutX="467.0" layoutY="189.0" text="Password and Confirmation Password don't match" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Label layoutX="599.0" layoutY="226.0" text="Password" wrapText="true">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <Label layoutX="308.0" layoutY="90.0" prefHeight="35.0" prefWidth="480.0" text="Please enter your account information below">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <Label layoutX="599.0" layoutY="326.0" styleClass="textField" text="Confirm Password">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <TextField fx:id="standardConfirmPasswordField" layoutX="598.0" layoutY="354.0" prefHeight="45.0" prefWidth="251.0" promptText="Confirm password">
            <font>
                <Font size="18.0" />
            </font>
        </TextField>
        <Label fx:id="confPasswordError" layoutX="469.0" layoutY="290.0" text="Password and Confirmation Password don't match" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Button fx:id="standardNextButton" layoutX="410.0" layoutY="558.0" mnemonicParsing="false" onAction="#onStandardAccountNextButtonClick" prefHeight="48.0" prefWidth="246.0" text="Next" />
        <Button id="backButton" layoutX="38.0" layoutY="28.0" mnemonicParsing="false" onAction="#onStandardAccountBackButtonClick" prefHeight="30.0" prefWidth="62.0" text="Back" />
    </children>
</AnchorPane>
