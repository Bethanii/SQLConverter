<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane id="landingPage" fx:id="landingPage" prefHeight="639.0" prefWidth="995.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.myjavafxapp.Controller">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
        <Button id="createAccountButton" layoutX="479.0" layoutY="273.0" mnemonicParsing="false" onAction="#onCreateAccountButtonClick" prefHeight="48.0" prefWidth="218.0" text="Create an Account" />
        <Button id="signInButton" layoutX="116.0" layoutY="273.0" mnemonicParsing="false" onAction="#onSignInButtonClick" prefHeight="48.0" prefWidth="218.0" text="Sign In" />
        <Text id="signInText" layoutX="132.0" layoutY="231.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Have an account?" textAlignment="CENTER" />
        <Text id="createAccountText" layoutX="486.0" layoutY="231.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Already registered?" textAlignment="CENTER" />
    </children>

</AnchorPane>
