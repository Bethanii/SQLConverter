<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.text.*?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="newPasswordPage" prefHeight="482.0" prefWidth="852.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.myjavafxapp.AccountController">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>
    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
        <Label fx:id="emailExistsError" layoutX="105.0" layoutY="190.0" text="Email already registered, please log in" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextField fx:id="enterprisePasswordInputField" layoutX="276.0" layoutY="154.0" prefHeight="45.0" prefWidth="251.0" promptText="New password">
            <font>
                <Font size="20.0" />
            </font>
        </TextField>
        <Label fx:id="passwordError" layoutX="467.0" layoutY="189.0" text="Password and Confirmation Password don't match" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Label layoutX="275.0" layoutY="117.0" text="New Password" wrapText="true">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <Label layoutX="277.0" layoutY="52.0" text="Enter new password below: ">
            <font>
                <Font size="22.0" />
            </font>
        </Label>
        <Label layoutX="275.0" layoutY="229.0" styleClass="textField" text="Confirm Password">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <TextField fx:id="enterpriseConfirmPasswordField" layoutX="275.0" layoutY="265.0" prefHeight="45.0" prefWidth="251.0" promptText="Confirm password">
            <font>
                <Font size="20.0" />
            </font>
        </TextField>
        <Label fx:id="confPasswordError" layoutX="469.0" layoutY="290.0" text="Password and Confirmation Password don't match" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Button fx:id="enterpriseNextButton" layoutX="289.0" layoutY="371.0" mnemonicParsing="false" onAction="#onEnterpriseAccountNextButtonClick" prefHeight="48.0" prefWidth="246.0" text="Next" />
    </children>
</AnchorPane>
