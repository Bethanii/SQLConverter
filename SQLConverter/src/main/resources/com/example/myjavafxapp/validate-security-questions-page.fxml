<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.text.*?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="validateSecurityQuestionsPage" prefHeight="482.0" prefWidth="852.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.myjavafxapp.Controller">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>

    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
        <TextField fx:id="response1" layoutX="191.0" layoutY="117.0" prefHeight="45.0" prefWidth="251.0" promptText="Enter response">
            <font>
                <Font size="20.0" />
            </font>
        </TextField>
        <Label fx:id="question1" layoutX="191.0" layoutY="76.0" text="Security Question 1">
            <font>
                <Font size="22.0" />
            </font>
        </Label>
        <Label fx:id="question2" layoutX="192.0" layoutY="190.0" text="Security Question 2">
            <font>
                <Font size="22.0" />
            </font>
        </Label>
        <TextField fx:id="response2" layoutX="191.0" layoutY="228.0" prefHeight="45.0" prefWidth="251.0" promptText="Enter response">
            <font>
                <Font size="20.0" />
            </font>
        </TextField>
        <Label fx:id="errorMessage" layoutX="192.0" layoutY="280.0" text="Incorrect security question response. Please try again" textFill="red" visible="false">
            <font>
                <Font size="22.0" />
            </font>
        </Label>
        <Button fx:id="standardNextButton" layoutX="295.0" layoutY="352.0" mnemonicParsing="false" onAction="#onValidateSecurityQuestionsNextClick" prefHeight="48.0" prefWidth="246.0" text="Next" />
    </children>
</AnchorPane>
