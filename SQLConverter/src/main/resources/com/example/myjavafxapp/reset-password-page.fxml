<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.text.*?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="resetPasswordPage" prefHeight="482.0" prefWidth="852.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.myjavafxapp.Controller">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>

    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
        <Label layoutX="234.0" layoutY="97.0" prefHeight="38.0" prefWidth="384.0" text="Enter the email associated to your account">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <TextField id="resetEmailField" fx:id="resetEmailField" layoutX="287.0" layoutY="177.0" prefHeight="45.0" prefWidth="251.0" promptText="Email">
            <font>
                <Font size="20.0" />
            </font>
        </TextField>
        <Label fx:id="emailExistsError" layoutX="105.0" layoutY="190.0" text="Email already registered, please log in" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Label fx:id="passwordError" layoutX="467.0" layoutY="189.0" text="Password and Confirmation Password don't match" textFill="red" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Button id="resetPasswordButton" fx:id="resetPasswordButton" layoutX="289.0" layoutY="350.0" mnemonicParsing="false" onAction="#onResetPasswordButton" prefHeight="48.0" prefWidth="246.0" text="Reset Password">
         <font>
            <Font size="18.0" />
         </font></Button>
      <Label id="tempPasswordMessage" layoutX="248.0" layoutY="241.0" textFill="red" text="Temporary password has been sent to the email provided">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
    </children>
</AnchorPane>
