<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import java.lang.*?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="sqlConverterPage" prefHeight="482.0" prefWidth="852.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.myjavafxapp.SQLConverterController">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>
    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
      <ScrollPane layoutX="470.0" layoutY="97.0" prefHeight="315.0" prefWidth="333.0">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0">
               <children>
                  <ListView layoutX="-4.0" prefHeight="315.0" prefWidth="333.0" />
               </children>
            </AnchorPane>
        </content>
      </ScrollPane>
      <ChoiceBox fx:id="searchRow1" layoutX="283.0" layoutY="102.0" prefHeight="33.0" prefWidth="167.0" />
      <TextField fx:id="searchField1" layoutX="35.0" layoutY="102.0" prefHeight="33.0" prefWidth="250.0" promptText="Enter value">
         <font>
            <Font size="14.0" />
         </font>
      </TextField>
      <Button layoutX="582.0" layoutY="427.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="110.0" text="Export Data">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Label layoutX="570.0" layoutY="52.0" prefHeight="17.0" prefWidth="134.0" text="Search Results">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField id="searchRow2" layoutX="35.0" layoutY="161.0" prefHeight="33.0" prefWidth="250.0" promptText="Enter value">
         <font>
            <Font size="14.0" />
         </font>
      </TextField>
      <ChoiceBox layoutX="283.0" layoutY="161.0" prefHeight="33.0" prefWidth="167.0" />
