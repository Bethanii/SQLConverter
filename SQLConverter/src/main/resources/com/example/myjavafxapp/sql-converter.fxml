         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Button id="connectButton" layoutX="117.0" layoutY="412.0" mnemonicParsing="false" onAction="#onConnectButtonClick" prefHeight="25.0" prefWidth="110.0" text="Connect">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button id="searchButton" layoutX="267.0" layoutY="412.0" mnemonicParsing="false" onAction="#onSearchButtonClick" prefHeight="25.0" prefWidth="110.0" text="Search">
