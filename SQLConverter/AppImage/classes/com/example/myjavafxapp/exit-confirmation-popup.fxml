<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>
<?import java.lang.*?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="exitConfirmation" prefHeight="318.0" prefWidth="557.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.myjavafxapp.AccountController">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>

    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
        <Label layoutX="100.0" layoutY="129.0" text="All account creation progress will be lost">
            <font>
                <Font size="20.0" />
            </font></Label>
      <Label layoutX="142.0" layoutY="83.0" text="Are you sure you want to exit? ">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Button fx:id="cancelOption" layoutX="296.0" layoutY="209.0" mnemonicParsing="false" prefHeight="41.0" prefWidth="99.0" onAction="#onPopUpCancel" style="-fx-background-color: white; -fx-border-color: black; -fx-border-width: 1.5;" text="Cancel">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button fx:id="exitOption" layoutX="146.0" layoutY="209.0" mnemonicParsing="false" prefHeight="41.0" prefWidth="99.0" onAction="#onPopUpExit"  style="-fx-background-color: #f44336; -fx-border-color: black; -fx-border-width: 1.5;" text="Exit">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
    </children>
</AnchorPane>
