<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.text.*?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="resetPasswordPage" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.myjavafxapp.Controller">

    <stylesheets>
        <URL value="@static/style.css" />
    </stylesheets>

    <children>
        <Label fx:id="welcomeText" styleClass="labelStyle" />
        <Label layoutX="287.0" layoutY="143.0" prefHeight="38.0" prefWidth="544.0" text="Please enter the email associated to your account">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <TextField id="resetEmailField" fx:id="resetEmailField" layoutX="410.0" layoutY="328.0" prefHeight="45.0" prefWidth="251.0" promptText="Email">
            <font>
                <Font size="18.0" />
            </font>
        </TextField>
        <Label fx:id="errorMessage" layoutX="287.0" layoutY="240.0" text="Error message" textFill="red" visible="false">
            <font>
                <Font size="16.0" />
            </font>
        </Label>
        <Button id="resetPasswordButton" fx:id="resetPasswordButton" layoutX="410.0" layoutY="558.0" mnemonicParsing="false" onAction="#onResetPasswordButton" prefHeight="48.0" prefWidth="246.0" text="Reset Password">
         <font>
            <Font size="18.0" />
         </font>
        </Button>
        <Button fx:id="backToHomeButton" layoutX="38.0" layoutY="28.0" mnemonicParsing="false" onAction="#onBackToHomeButtonClick" prefHeight="30.0" prefWidth="116.0" text="Back to Home" visible="false">
            <font>
                <Font size="14.0" />
            </font>
        </Button>
        <Button fx:id="updatePasswordButton" layoutX="410.0" layoutY="558.0" mnemonicParsing="false" prefHeight="48.0" prefWidth="246.0" text="Update Password" visible="false"/>
    </children>
</AnchorPane>
